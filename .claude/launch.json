{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "src/web",
      "port": 3000
    },
    {
      "name": "api",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "api.main:app", "--reload", "--port", "8000"],
      "env": { "PYTHONPATH": "src" },
      "port": 8000
    }
  ]
}

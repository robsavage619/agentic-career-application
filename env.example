# Setup: cp env.example .env.local  (then fill in your values)
# .env.local is gitignored — never commit real keys

ANTHROPIC_API_KEY=

ADZUNA_APP_ID=
ADZUNA_APP_KEY=

JSEARCH_RAPIDAPI_KEY=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Obsidian Local REST API (already running on your machine)
OBSIDIAN_API_PORT=27124

# Local SQLite — stored on your machine only
DATABASE_URL=sqlite:///./career_command_center.db
